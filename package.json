{
  "name": "meshysmith",
  "version": "0.4.0",
  "private": true,
  "description": "MeshySmith - local-first 3D design editor.",
  "author": {
    "name": "f00d4tehg0dz"
  },
  "license": "AGPL-3.0-or-later",
  "main": "deploy/electron/main.js",
  "scripts": {
    "dev": "next dev apps/web",
    "dev:clean": "rimraf apps/web/.next && next dev apps/web",
    "clean": "rimraf apps/web/.next apps/web/out",
    "icons:generate": "node scripts/generate-icons.mjs",
    "build": "next build apps/web",
    "export": "cross-env STATIC_EXPORT=true next build apps/web",
    "start": "next start apps/web",
    "typecheck": "tsc -p apps/web/tsconfig.json --noEmit",
    "test": "vitest run --config tests/vitest.config.ts",
    "test:watch": "vitest --config tests/vitest.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "perf": "vitest run --config tests/vitest.perf.config.ts --reporter verbose",
    "ci": "npm run typecheck && npm run test",
    "docker:build": "docker build -f deploy/docker/Dockerfile -t meshysmith:local .",
    "docker:run": "docker run --rm -p 3000:80 meshysmith:local",
    "docker:up": "docker compose -f deploy/docker/compose.yaml up --build -d",
    "docker:down": "docker compose -f deploy/docker/compose.yaml down",
    "electron": "electron .",
    "electron:dev": "npm run export && electron .",
    "electron:dist": "npm run export && electron-builder --config deploy/electron/electron-builder.yml",
    "electron:dist:win": "npm run export && electron-builder --config deploy/electron/electron-builder.yml --win",
    "electron:dist:mac": "npm run export && electron-builder --config deploy/electron/electron-builder.yml --mac",
    "electron:dist:linux": "npm run export && electron-builder --config deploy/electron/electron-builder.yml --linux"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.14",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-navigation-menu": "^1.2.16",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/three": "0.184.1",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "manifold-3d": "^3.5.1",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "three": "0.184.0",
    "three-bvh-csg": "^0.0.18",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "png-to-ico": "^3.0.1",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
